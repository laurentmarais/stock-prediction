// Value Line V01
//
// This indicator estimates a stock's fair value by combining four valuation models:
// 1) P/E-based fair value: EPS × average historical P/E
// 2) P/S-based fair value: Revenue per share × average historical P/S
// 3) P/B-based fair value: Book value per share × average historical P/B
// 4) P/NAV-based fair value: NAV per share × average historical P/NAV
//
// NAV per share is calculated as:
// (Total Assets - Total Liabilities) / Shares Outstanding
//
// For each financial metric, the script automatically checks multiple reporting periods
// and uses the first valid one available for the current stock.
//
// The final fair value is a weighted average of the available component fair values,
// using the user-defined weights for P/E, P/S, P/B, and P/NAV.
//
// The indicator then plots that fair value directly on the main price chart and can
// optionally shade the area between the current price and the estimated fair value.
//@version=5
indicator("Value Line V04", overlay = true)

// -------- INPUTS --------
grpModel = "Valuation Model"
multipleLookback = input.int(300, "Multiple lookback", minval = 50, group = grpModel)
peWeight = input.float(1.0, "P/E weight", minval = 0, step = 0.25, group = grpModel)
psWeight = input.float(1.0, "P/S weight", minval = 0, step = 0.25, group = grpModel)
pbWeight = input.float(1.0, "P/B weight", minval = 0, step = 0.25, group = grpModel)
navWeight = input.float(1.0, "P/NAV weight", minval = 0, step = 0.25, group = grpModel)

grpSignals = "Signals"
zLookback = input.int(200, "Z-score lookback", minval = 50, group = grpSignals)
undervaluedLevel = input.float(-1.6, "Undervalued z-score", step = 0.1, group = grpSignals)
deepUndervaluedLevel = input.float(-2.5, "Deep undervalued z-score", step = 0.1, group = grpSignals)
overvaluedLevel = input.float(2.0, "Overvalued z-score", step = 0.1, group = grpSignals)
minUpsidePct = input.float(20.0, "Minimum upside %", minval = 0, step = 1, group = grpSignals)

grpTech = "Technical Filters"
emaFastLen = input.int(20, "Fast EMA", minval = 2, group = grpTech)
emaSlowLen = input.int(50, "Slow EMA", minval = 2, group = grpTech)
trendLen = input.int(200, "Trend MA", minval = 20, group = grpTech)
rsiLen = input.int(14, "RSI length", minval = 2, group = grpTech)
rsiTrigger = input.int(40, "RSI trigger", minval = 1, maxval = 99, group = grpTech)

grpDisplay = "Display"
showFairValueLine = input.bool(true, "Show fair value line", group = grpDisplay)
showPremiumDiscountFill = input.bool(true, "Show premium/discount fill", group = grpDisplay)
showSignalBackground = input.bool(true, "Show signal background", group = grpDisplay)
showPanel = input.bool(true, "Show panel", group = grpDisplay)
panelLocationInput = input.string("Top Right", "Panel location", options = ["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group = grpDisplay)

grpColors = "Colors"
fairValueLineColor = input.color(color.blue, "Fair value line", group = grpColors)
undervaluedFillColor = input.color(color.new(color.green, 88), "Undervalued fill", group = grpColors)
overvaluedFillColor = input.color(color.new(color.red, 88), "Overvalued fill", group = grpColors)
deepUndervaluedBgColor = input.color(color.new(color.teal, 88), "Deep undervalued background", group = grpColors)
undervaluedBgColor = input.color(color.new(color.green, 90), "Undervalued background", group = grpColors)
exitRiskBgColor = input.color(color.new(color.red, 85), "Exit risk background", group = grpColors)
panelBgColor = input.color(color.rgb(230, 230, 230), "Panel background", group = grpColors)
panelTextColor = input.color(color.black, "Panel label text", group = grpColors)
positiveTextColor = input.color(color.rgb(0, 100, 0), "Positive text", group = grpColors)
negativeTextColor = input.color(color.rgb(139, 0, 0), "Negative text", group = grpColors)

panelLocation = switch panelLocationInput
	"Top Left" => position.top_left
	"Bottom Left" => position.bottom_left
	"Bottom Right" => position.bottom_right
	=> position.top_right

// -------- FINANCIAL DATA --------
epsTTM = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE", "TTM", ignore_invalid_symbol = true)
epsFQ = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE", "FQ", ignore_invalid_symbol = true)
epsFH = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE", "FH", ignore_invalid_symbol = true)
epsFY = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE", "FY", ignore_invalid_symbol = true)

revenueTTM = request.financial(syminfo.tickerid, "TOTAL_REVENUE", "TTM", ignore_invalid_symbol = true)
revenueFQ = request.financial(syminfo.tickerid, "TOTAL_REVENUE", "FQ", ignore_invalid_symbol = true)
revenueFH = request.financial(syminfo.tickerid, "TOTAL_REVENUE", "FH", ignore_invalid_symbol = true)
revenueFY = request.financial(syminfo.tickerid, "TOTAL_REVENUE", "FY", ignore_invalid_symbol = true)

sharesFQ = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FQ", ignore_invalid_symbol = true)
sharesFH = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FH", ignore_invalid_symbol = true)
sharesFY = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FY", ignore_invalid_symbol = true)

assetsFQ = request.financial(syminfo.tickerid, "TOTAL_ASSETS", "FQ", ignore_invalid_symbol = true)
assetsFH = request.financial(syminfo.tickerid, "TOTAL_ASSETS", "FH", ignore_invalid_symbol = true)
assetsFY = request.financial(syminfo.tickerid, "TOTAL_ASSETS", "FY", ignore_invalid_symbol = true)

liabFQ = request.financial(syminfo.tickerid, "TOTAL_LIABILITIES", "FQ", ignore_invalid_symbol = true)
liabFH = request.financial(syminfo.tickerid, "TOTAL_LIABILITIES", "FH", ignore_invalid_symbol = true)
liabFY = request.financial(syminfo.tickerid, "TOTAL_LIABILITIES", "FY", ignore_invalid_symbol = true)

bookFQ = request.financial(syminfo.tickerid, "BOOK_VALUE_PER_SHARE", "FQ", ignore_invalid_symbol = true)
bookFH = request.financial(syminfo.tickerid, "BOOK_VALUE_PER_SHARE", "FH", ignore_invalid_symbol = true)
bookFY = request.financial(syminfo.tickerid, "BOOK_VALUE_PER_SHARE", "FY", ignore_invalid_symbol = true)

string epsPeriod = not na(epsTTM) ? "TTM" : not na(epsFQ) ? "FQ" : not na(epsFH) ? "FH" : not na(epsFY) ? "FY" : ""
string revenuePeriod = not na(revenueTTM) ? "TTM" : not na(revenueFQ) ? "FQ" : not na(revenueFH) ? "FH" : not na(revenueFY) ? "FY" : ""
string sharesPeriod = not na(sharesFQ) and sharesFQ != 0 ? "FQ" : not na(sharesFH) and sharesFH != 0 ? "FH" : not na(sharesFY) and sharesFY != 0 ? "FY" : ""
string bookPeriod = not na(bookFQ) ? "FQ" : not na(bookFH) ? "FH" : not na(bookFY) ? "FY" : ""
string navPeriod = not na(assetsFQ) and not na(liabFQ) and not na(sharesFQ) and sharesFQ != 0 ? "FQ" : not na(assetsFH) and not na(liabFH) and not na(sharesFH) and sharesFH != 0 ? "FH" : not na(assetsFY) and not na(liabFY) and not na(sharesFY) and sharesFY != 0 ? "FY" : ""

eps = epsPeriod == "TTM" ? epsTTM : epsPeriod == "FQ" ? epsFQ : epsPeriod == "FH" ? epsFH : epsPeriod == "FY" ? epsFY : na
revenue = revenuePeriod == "TTM" ? revenueTTM : revenuePeriod == "FQ" ? revenueFQ : revenuePeriod == "FH" ? revenueFH : revenuePeriod == "FY" ? revenueFY : na
shares = sharesPeriod == "FQ" ? sharesFQ : sharesPeriod == "FH" ? sharesFH : sharesPeriod == "FY" ? sharesFY : na
book = bookPeriod == "FQ" ? bookFQ : bookPeriod == "FH" ? bookFH : bookPeriod == "FY" ? bookFY : na
assets = navPeriod == "FQ" ? assetsFQ : navPeriod == "FH" ? assetsFH : navPeriod == "FY" ? assetsFY : na
liabilities = navPeriod == "FQ" ? liabFQ : navPeriod == "FH" ? liabFH : navPeriod == "FY" ? liabFY : na
nav = not na(assets) and not na(liabilities) and not na(shares) and shares != 0 ? (assets - liabilities) / shares : na

// -------- FAIR VALUE ENGINE --------
revenuePS = not na(revenue) and not na(shares) and shares != 0 ? revenue / shares : na

pe = not na(eps) and eps != 0 ? close / eps : na
ps = not na(revenuePS) and revenuePS != 0 ? close / revenuePS : na
pb = not na(book) and book != 0 ? close / book : na
pnav = not na(nav) and nav != 0 ? close / nav : na

avgPE = ta.sma(pe, multipleLookback)
avgPS = ta.sma(ps, multipleLookback)
avgPB = ta.sma(pb, multipleLookback)
avgPNAV = ta.sma(pnav, multipleLookback)

fairPE = not na(eps) and eps > 0 and not na(avgPE) and avgPE > 0 ? eps * avgPE : na
fairPS = not na(revenuePS) and revenuePS > 0 and not na(avgPS) and avgPS > 0 ? revenuePS * avgPS : na
fairPB = not na(book) and book > 0 and not na(avgPB) and avgPB > 0 ? book * avgPB : na
fairNAV = not na(nav) and nav > 0 and not na(avgPNAV) and avgPNAV > 0 ? nav * avgPNAV : na

weightedFairSum = (not na(fairPE) ? fairPE * peWeight : 0) + (not na(fairPS) ? fairPS * psWeight : 0) + (not na(fairPB) ? fairPB * pbWeight : 0) + (not na(fairNAV) ? fairNAV * navWeight : 0)
totalFairWeight = (not na(fairPE) ? peWeight : 0) + (not na(fairPS) ? psWeight : 0) + (not na(fairPB) ? pbWeight : 0) + (not na(fairNAV) ? navWeight : 0)
fairValue = totalFairWeight > 0 ? weightedFairSum / totalFairWeight : na

upsidePct = not na(fairValue) and close != 0 ? ((fairValue / close) - 1) * 100 : na
priceVsFairPct = not na(fairValue) and fairValue != 0 ? ((close / fairValue) - 1) * 100 : na

// -------- SIGNAL ENGINE --------
deviation = not na(fairValue) and fairValue != 0 ? (close - fairValue) / fairValue : na
meanDev = ta.sma(deviation, zLookback)
stdDev = ta.stdev(deviation, zLookback)
zScore = not na(stdDev) and stdDev != 0 ? (deviation - meanDev) / stdDev : na

emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
trendMA = ta.sma(close, trendLen)
rsi = ta.rsi(close, rsiLen)

uptrend = close > trendMA and emaFast > emaSlow
trendImproving = close > emaFast and emaFast > emaFast[5] and emaSlow > emaSlow[5]
undervalued = not na(zScore) and zScore < undervaluedLevel
deepUndervalued = not na(zScore) and zScore < deepUndervaluedLevel
overvalued = not na(zScore) and zScore > overvaluedLevel
enoughUpside = not na(upsidePct) and upsidePct >= minUpsidePct

exitRisk = overvalued and (close < emaFast or ta.crossunder(rsi, 60))
deepUndervaluedBreach = ta.crossunder(zScore, deepUndervaluedLevel)

fmtPrice(v) => na(v) ? "n/a" : str.tostring(v, format.mintick)
fmtPct(v) => na(v) ? "n/a" : str.tostring(v, "0.0") + "%"

// -------- PLOTS --------
pricePlot = plot(showPremiumDiscountFill ? close : na, title = "Price reference", color = color.new(color.gray, 100), display = display.none)
fairValuePlot = plot(showFairValueLine ? fairValue : na, title = "Fair Value", color = fairValueLineColor, linewidth = 2)

fill(pricePlot, fairValuePlot, color = showPremiumDiscountFill ? (not na(fairValue) and fairValue > close ? undervaluedFillColor : not na(fairValue) and fairValue < close ? overvaluedFillColor : na) : na, title = "Price vs Fair Value")

// -------- SIGNAL HIGHLIGHTS --------
signalZoneColor = exitRisk ? exitRiskBgColor : deepUndervalued ? deepUndervaluedBgColor : undervalued ? undervaluedBgColor : na
fill(pricePlot, fairValuePlot, color = showSignalBackground ? signalZoneColor : na, title = "Signal Zone Fill")

alertcondition(deepUndervaluedBreach, title = "Deep Undervalued Breach", message = "Z-score breached the deep undervalued limit")

// -------- PANEL --------
var table panel = na
if showPanel and na(panel)
	panel := table.new(panelLocation, 2, 7, bgcolor = panelBgColor, border_width = 1)
if not showPanel and not na(panel)
	table.delete(panel)
	panel := na

if barstate.islast and showPanel and not na(panel)
	table.cell(panel, 0, 0, "Fair value", text_color = panelTextColor, bgcolor = panelBgColor)
	table.cell(panel, 1, 0, fmtPrice(fairValue), text_color = panelTextColor, bgcolor = panelBgColor)

	table.cell(panel, 0, 1, "Upside", text_color = panelTextColor, bgcolor = panelBgColor)
	table.cell(panel, 1, 1, fmtPct(upsidePct), text_color = not na(upsidePct) and upsidePct >= 0 ? positiveTextColor : negativeTextColor, bgcolor = panelBgColor)

	table.cell(panel, 0, 2, "Price vs FV", text_color = panelTextColor, bgcolor = panelBgColor)
	table.cell(panel, 1, 2, fmtPct(priceVsFairPct), text_color = not na(priceVsFairPct) and priceVsFairPct <= 0 ? positiveTextColor : negativeTextColor, bgcolor = panelBgColor)

	table.cell(panel, 0, 3, "NAV/share", text_color = panelTextColor, bgcolor = panelBgColor)
	table.cell(panel, 1, 3, fmtPrice(nav), text_color = panelTextColor, bgcolor = panelBgColor)

	table.cell(panel, 0, 4, "Periods", text_color = panelTextColor, bgcolor = panelBgColor)
	table.cell(panel, 1, 4, "EPS " + epsPeriod + " | Rev " + revenuePeriod, text_color = panelTextColor, bgcolor = panelBgColor)

	table.cell(panel, 0, 5, "Balance", text_color = panelTextColor, bgcolor = panelBgColor)
	table.cell(panel, 1, 5, "Book " + bookPeriod + " | NAV " + navPeriod, text_color = panelTextColor, bgcolor = panelBgColor)

	table.cell(panel, 0, 6, "Weights", text_color = panelTextColor, bgcolor = panelBgColor)
	table.cell(panel, 1, 6, "PE " + str.tostring(peWeight, "0.##") + " PS " + str.tostring(psWeight, "0.##") + " PB " + str.tostring(pbWeight, "0.##") + " NAV " + str.tostring(navWeight, "0.##"), text_color = panelTextColor, bgcolor = panelBgColor)
